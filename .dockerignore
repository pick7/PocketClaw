# macOS 资源分叉文件（插入USB时自动生成，会导致Docker构建失败）
._*
.DS_Store
.Spotlight-V100
.fseventsd
.Trashes

# Windows 系统文件
Thumbs.db
desktop.ini
System Volume Information

# 运行时数据
data/sessions/*
data/logs/*
data/credentials/*

# Git
.git
.gitignore

# 加密密钥
secrets/*.key
secrets/*.pem

# Windows 专用脚本（容器内不需要）
scripts/*.bat
scripts/*.ps1

# 文档文件（构建镜像不需要）
使用指南.txt
README.md
LICENSE.md
*.command
*.bat
