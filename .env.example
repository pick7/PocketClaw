# ============================================
# PocketClaw 环境变量配置
# 复制此文件为 .env 并填入实际值:
#   copy .env.example .env    (Windows)
#   cp .env.example .env      (macOS/Linux)
#
# 或者直接运行配置向导: scripts/setup-env.bat (Windows)
#                       bash scripts/setup-env.sh (macOS/Linux)
# ============================================

# ---------- Docker Compose 项目名 ----------
COMPOSE_PROJECT_NAME=pocketclaw

# ---------- 默认模型 ----------
OPENCLAW_MODEL=zhipu/glm-4.7-flash

# ---------- 智谱 AI (GLM-4.7-Flash 永久免费) ----------
# 获取方式:
#   1. 打开 https://open.bigmodel.cn
#   2. 用手机号注册/登录
#   3. 进入「API密钥」页面 → 添加新 API Key → 复制
ZHIPU_API_KEY=

# ---------- Gateway 认证密码 ----------
# 用于保护 WebSocket 连接，默认值: pocketclaw
GATEWAY_AUTH_PASSWORD=pocketclaw

